# ══════════════════════════════════════════════
#  Pão FresQUIM — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha
# ══════════════════════════════════════════════

# ── Banco de Dados (Supabase) ──────────────────
# Encontre em: Supabase → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[SENHA]@db.[PROJETO].supabase.co:5432/postgres

# ── Servidor ───────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# ── Sessão ─────────────────────────────────────
# Use uma string longa e aleatória em produção!
SESSION_SECRET=paofresquim-secret-dev

# ── E-mail (recuperação de senha) ─────────────
# Deixe em branco para usar modo simulado (log no console)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seuemail@gmail.com
EMAIL_PASS=sua-senha-app
EMAIL_FROM=Pão FresQUIM <seuemail@gmail.com>

# ── Serasa (consulta de CPF) ───────────────────
# Deixe em branco para usar modo simulado
# Obtenha em: https://developers.serasa.com.br
SERASA_URL=https://api.serasaexperian.com.br
SERASA_CLIENT_ID=
SERASA_CLIENT_SECRET=

# ── Twilio (WhatsApp e SMS) ────────────────────
# Obtenha em: https://console.twilio.com
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886   # número sandbox do Twilio WhatsApp
TWILIO_SMS_FROM=                    # número Twilio para SMS
